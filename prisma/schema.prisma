generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  ADMIN
  APPROVER
  EDITOR
  DISTRIBUTOR
  VIEWER
}

enum B2BApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DistributorOrderState {
  ACCEPTED
  OUT_FOR_DELIVERY
  REJECTED
  DELIVERED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  shopifyCustomerId String?
  role      RoleName @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  distributorRegions DistributorRegion[]
  auditLogs          AuditLog[]
}

model DistributorRegion {
  id        String   @id @default(cuid())
  userId    String
  country   String
  region    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, country, region])
}

model B2BApplication {
  id                String               @id @default(cuid())
  shopifyCustomerId String?
  email             String
  contactName       String
  businessName      String
  taxId             String?
  message           String?
  status            B2BApplicationStatus @default(PENDING)
  reviewedById      String?
  reviewedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model Influencer {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  codes InfluencerCode[]
}

model InfluencerCode {
  id           String   @id @default(cuid())
  influencerId String
  code         String   @unique
  commissionRate Decimal?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  influencer  Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  attributions OrderAttribution[]
}

model OrderAttribution {
  id               String   @id @default(cuid())
  shopifyOrderId   String
  influencerCodeId String
  subtotalAmount   Decimal
  currencyCode     String
  createdAt        DateTime @default(now())

  influencerCode InfluencerCode @relation(fields: [influencerCodeId], references: [id], onDelete: Cascade)

  @@unique([shopifyOrderId, influencerCodeId])
}

model DistributorOrderStatus {
  id             String                @id @default(cuid())
  shopifyOrderId String                @unique
  state          DistributorOrderState
  region         String
  updatedById    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

model WebhookEvent {
  id          String   @id @default(cuid())
  webhookId   String?  @unique
  topic       String
  shop        String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime @default(now())
}
